# ── ClearView environment variables ──────────────────────────────
# Copy to .env.local for local dev. Never commit .env.local.

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Model used for analysis generation. Override when a better
# price/quality option ships; nothing else in the code names a model.
ANTHROPIC_MODEL=claude-sonnet-5

# Finnhub — https://finnhub.io/dashboard (free tier)
FINNHUB_API_KEY=...

# Neon Postgres connection string — https://neon.tech
# (or via the Vercel Postgres integration, which is Neon underneath)
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# bcrypt hash of the owner password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
APP_PASSWORD_HASH=$2b$12$...

# Random secret for signing session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=...
